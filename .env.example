# Supabase (필수)
# 대시보드: https://supabase.com/dashboard → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버 전용 (관리자·배치용)
SUPABASE_SERVICE_ROLE_KEY=

# Vertex AI (Gemini) — GCP $300 크레딧 등 결제 계정으로 과금
# 서비스 계정 JSON 파일 전체를 한 줄로 넣거나, 배포 환경에서는 시크릿으로 주입
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 선택: JSON에 project_id가 있으면 생략 가능
GOOGLE_CLOUD_PROJECT=
# 리전 (모델 가용 리전에 맞게, 예: us-central1, asia-northeast3)
GOOGLE_CLOUD_LOCATION=us-central1
# 선택: Vertex 기본 모델(프로젝트/리전에 따라 preview 모델은 접근이 안 될 수 있습니다)
# GOOGLE_CLOUD_VERTEX_MODEL=gemini-2.5-flash

# 관리자 가입 코드
ADMIN_CODE=

# 슈퍼관리자(본인 구글 계정 이메일) — 대시보드에서 AI 백엔드 전환 UI 허용
# SUPER_ADMIN_EMAIL=you@gmail.com

# Gemini API (키 방식, ai_provider=gemini 일 때 사용)
# GEMINI_API_KEY=
# 선택 모델 (기본 gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
